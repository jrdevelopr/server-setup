# Your filled-in deployment config (identifies your server) — keep it out of git.
lab.conf

# Per-app Caddy route snippets are generated by deploy.sh on each host.
caddy/apps.d/*.caddy
!caddy/apps.d/.gitkeep

# Standard cruft / secrets (defense in depth; the global gitignore covers more)
*.env
*.pem
*.key
.DS_Store
*.swp
