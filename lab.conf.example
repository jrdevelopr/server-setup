# ─────────────────────────────────────────────────────────────────────────
#  lab.conf — the ONE place you set deployment-specific values.
#  Easiest: run `./configure.sh` — it prompts for these and writes lab.conf for you.
#  By hand instead:  cp lab.conf.example lab.conf && nano lab.conf
#  `lab.conf` is gitignored (it identifies your deployment); this .example is not.
#  All scripts source it via bin/lib.sh. Paths derive from the repo location,
#  so nothing is tied to a specific home directory.
# ─────────────────────────────────────────────────────────────────────────

# Your domain — must already be added to Cloudflare with NS pointed there.
DOMAIN="example.site"

# The server's LAN/VPN IP (how YOU reach apps directly, bypassing the tunnel/gate).
LAN_IP="<server-lan-ip>"

# The OS login user that owns ~/server-setup and ~/apps (used for native systemd units).
LAB_USER="examplelab"

# Short name for this lab → the secrets directory /etc/LAB_NAME (root, chmod 600).
# Name it whatever you like: devlab, homelab, ...
LAB_NAME="examplelab"

# The Cloudflare tunnel name (you create it with: cloudflared tunnel create TUNNEL).
TUNNEL="examplelab-tunnel"

# GitHub account/org that holds the app repos + Project boards.
GITHUB_OWNER="example-org"

# Host timezone (bootstrap.sh runs `timedatectl set-timezone`). Use a tz database name.
TIMEZONE="America/New_York"

# Git commit identity for this host (bootstrap.sh sets these globally). Avoids inheriting
# a stray pre-existing identity for the repos this lab creates.
GIT_USER_NAME="Lab Operator"
GIT_USER_EMAIL="you@example.com"

# ── Shared login (ONE identity across the gate splash page + every app) ──────
ADMIN_USER="admin"               # login username (use ADMIN_EMAIL where an app requires an email)
ADMIN_EMAIL="you@example.com"    # email identity for apps that key on email
LAB_PASSWORD=""                  # the ONE production password, used everywhere — SET THIS before
                                 # running. Host-local SECRET: lab.conf is gitignored; keep it
                                 # chmod 600 and NEVER commit it.

# Host-port range auto-assigned to apps (one per app).
PORT_MIN=8080
PORT_MAX=8099

# Fixed infrastructure ports (match your Caddyfile):
DASHBOARD_PORT=5005   # the dashboard (Flame) — also the :80 catch-all target
GATE_PORT=8082        # the login gateway (forward-auth) — the (gate) snippet target
